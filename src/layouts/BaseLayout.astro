---
import BaseHead from '@/components/seo/BaseHead.astro'
import Header from '@/components/layout/Header.astro'
import Footer from '@/components/layout/Footer.astro'
import JsonLd from '@/components/seo/JsonLd.astro'
import { getSiteSettings } from '@/lib/microcms'
import { buildWebSiteSchema } from '@/lib/schema'
import type { SEOProps } from '@/types'
import '@/styles/global.css'

interface Props extends SEOProps {
  class?: string
}

const {
  title,
  description,
  ogImage,
  canonical,
  noindex = false,
  class: className,
} = Astro.props

const settings = await getSiteSettings()
const webSiteSchema = buildWebSiteSchema()
---

<!doctype html>
<html lang="ja">
  <head>
    <BaseHead
      title={title}
      description={description || settings.siteDescription}
      ogImage={ogImage || settings.defaultOgImage?.url}
      canonical={canonical}
      noindex={noindex}
      gaMeasurementId={settings.gaMeasurementId}
      gscVerificationCode={settings.gscVerificationCode}
    />
    <JsonLd schemas={[webSiteSchema]} />
    <slot name="head" />
  </head>
  <body class="min-h-screen flex flex-col font-sans text-[var(--color-ink)]">
    <Header
      xUrl={settings.xurl}
      githubUrl={settings.githubUrl}
    />

    <main class:list={['flex-1 pt-16', className]}>
      <div class="page-enter">
        <slot />
      </div>
    </main>

    <Footer
      xUrl={settings.xurl}
      githubUrl={settings.githubUrl}
    />

    <script is:inline>
      (() => {
        const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        const revealNodes = Array.from(document.querySelectorAll('[data-reveal]'));
        if (revealNodes.length) {
          if (prefersReducedMotion) {
            revealNodes.forEach((node) => node.classList.add('is-visible'));
          } else {
            const observer = new IntersectionObserver((entries, currentObserver) => {
              entries.forEach((entry) => {
                if (!entry.isIntersecting) return;
                entry.target.classList.add('is-visible');
                currentObserver.unobserve(entry.target);
              });
            }, {
              threshold: 0.14,
              rootMargin: '0px 0px -8% 0px',
            });

            revealNodes.forEach((node) => observer.observe(node));
          }
        }

        if (prefersReducedMotion) return;

        const parallaxNodes = Array.from(document.querySelectorAll('[data-parallax]'));
        if (!parallaxNodes.length) return;

        let ticking = false;

        const updateParallax = () => {
          const viewportHeight = window.innerHeight || 1;

          parallaxNodes.forEach((node) => {
            const rect = node.getBoundingClientRect();
            const centerOffset = rect.top + rect.height / 2 - viewportHeight / 2;
            const shift = Math.max(-22, Math.min(22, centerOffset * -0.045));
            node.style.setProperty('--parallax-y', `${shift}px`);
          });

          ticking = false;
        };

        const requestTick = () => {
          if (ticking) return;
          ticking = true;
          window.requestAnimationFrame(updateParallax);
        };

        updateParallax();
        window.addEventListener('scroll', requestTick, { passive: true });
        window.addEventListener('resize', requestTick);
      })();
    </script>
  </body>
</html>
