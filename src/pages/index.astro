---
import BaseLayout from '@/layouts/BaseLayout.astro'
import Hero from '@/components/sections/Hero.astro'
import FeaturedBuilds from '@/components/sections/FeaturedBuilds.astro'
import FeaturedNotes from '@/components/sections/FeaturedNotes.astro'
import ContactCta from '@/components/sections/ContactCta.astro'
import JsonLd from '@/components/seo/JsonLd.astro'
import { getBuilds, getNotes } from '@/lib/microcms'
import { buildProfilePageSchema } from '@/lib/schema'

const [{ contents: featuredBuilds }, dailybrew] = await Promise.all([
  getBuilds({ featured: true, limit: 3 }),
  (await import('@/lib/microcms')).getBuildBySlug('dailybrew'),
])
const heroBuilds = featuredBuilds.slice(0, 2)
if (dailybrew && !heroBuilds.some((b) => b.slug === 'dailybrew')) {
  heroBuilds.push(dailybrew)
}
const { contents: featuredNotes } = await getNotes({ featured: true, limit: 3 })

const profileSchema = buildProfilePageSchema()
---

<BaseLayout description="AIとコードで、情報・運用・体験を組み直す開発者 KAMO のサイト。AI実装、自動化、プロダクト設計の実績と開発ログを公開。">
  <Fragment slot="head">
    <JsonLd schemas={[profileSchema]} />
  </Fragment>

  <Hero builds={heroBuilds} />
  <FeaturedBuilds builds={featuredBuilds} />
  <FeaturedNotes notes={featuredNotes} />
  <ContactCta />
</BaseLayout>
