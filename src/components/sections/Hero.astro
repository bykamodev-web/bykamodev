---
import Icon from '@/components/icons/Icons.astro'
import { getOptimizedImageUrl } from '@/lib/microcms'
import type { Build } from '@/types'

interface Props {
  builds?: Build[]
}

const { builds = [] } = Astro.props

const showcaseBuilds = builds.slice(0, 3).map((build) => ({
  title: build.title,
  summary: build.summary,
  href: `/builds/${build.slug}`,
  imageSm: getOptimizedImageUrl(build.coverImage.url, { width: 350, quality: 60, aspectRatio: '3:2' }),
  imageLg: getOptimizedImageUrl(build.coverImage.url, { width: 500, quality: 65, aspectRatio: '3:2' }),
}))

const capabilityRows = [
  { label: 'AI Integration', text: 'LLMを活用した動的なUI生成や、業務プロセスの自動化実装。', icon: 'brain' as const },
  { label: 'Automation', text: '運用と配信を、小さな判断単位まで自動化する。', icon: 'gear' as const },
  { label: 'Product Systems', text: 'Webアプリとデータ導線を、一つの体験として設計する。', icon: 'layers' as const },
]

const proofRows = [
  { index: '01', label: 'Builds', text: '本番運用中のプロダクト' },
  { index: '02', label: 'Notes', text: '設計やコードの断片' },
  { index: '03', label: 'Structure', text: '堅牢なアーキテクチャ' },
]
---

<section class="hero-shell">
  <div class="hero-atmosphere" aria-hidden="true">
    <div class="hero-orb hero-orb-a" data-parallax></div>
    <div class="hero-orb hero-orb-b" data-parallax></div>
    <div class="hero-grid"></div>
  </div>

  <div class="max-w-[1280px] mx-auto px-6 md:px-12 py-10 md:py-14">
    <div class="hero-layout">
      <div class="hero-copy reveal" data-reveal>
        <p class="section-label text-[var(--color-brand)] mb-5 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-[var(--color-brand)] animate-pulse"></span>
          Developer / KAMO
        </p>
        <div class="space-y-6">
          <h1 class="hero-site-title">bykamo<span class="text-[var(--color-ink-subtle)]">.</span>dev</h1>
          <p class="hero-title">
            AIとコードで、
            <br />
            情報・運用・体験を組み直す。
          </p>
          <p class="body-text-lg max-w-xl">
            複雑なシステム要件を解きほぐし、スケールするフロントエンドと自動化基盤を設計します。ただ動くものではなく、運用者とユーザーの双方にとって「最適化された構造」を実装します。
          </p>
        </div>

        <div class="hero-actions">
          <a href="/builds" class="group btn-primary">
            View Builds
            <Icon name="arrow-right" size={14} class="hover-arrow" />
          </a>
          <a href="/about" class="group btn-ghost">
            About KAMO
          </a>
        </div>
      </div>

      <div class="hero-visual-wrap reveal" data-reveal style="--delay:160ms;">
        <div class="hero-cards-stack">
          <!-- Card 3 (Back) - Placeholder -->
          <div class="hero-card-back glass-panel" aria-hidden="true">
            <div class="h-4 w-1/3 bg-[var(--color-ink-subtle)]/20 rounded mb-4"></div>
            <div class="space-y-2">
              <div class="h-2 w-full bg-[var(--color-ink-subtle)]/10 rounded"></div>
              <div class="h-2 w-5/6 bg-[var(--color-ink-subtle)]/10 rounded"></div>
              <div class="h-2 w-4/6 bg-[var(--color-ink-subtle)]/10 rounded"></div>
            </div>
          </div>

          <!-- Card 2 (Middle) - Dashboard -->
          <div class="hero-card-mid glass-panel">
            <div class="flex justify-between items-center mb-6">
              <span class="text-xs font-mono text-[var(--color-ink-muted)]">sys.monitor_</span>
              <Icon name="chart" size={16} class="text-[var(--color-brand)]" />
            </div>
            <div class="grid grid-cols-2 gap-3 flex-grow">
              <div class="bg-white/50 rounded-xl p-4 border border-[rgba(18,20,23,0.05)]">
                <div class="text-[0.65rem] text-[var(--color-ink-muted)] mb-1 uppercase font-bold">Uptime</div>
                <div class="text-xl font-bold text-[var(--color-ink)]">99.9%</div>
              </div>
              <div class="bg-white/50 rounded-xl p-4 border border-[rgba(18,20,23,0.05)]">
                <div class="text-[0.65rem] text-[var(--color-ink-muted)] mb-1 uppercase font-bold">Latency</div>
                <div class="text-xl font-bold text-[var(--color-ink)]">42ms</div>
              </div>
              <div class="col-span-2 bg-gradient-to-r from-[var(--color-brand-light)] to-transparent rounded-xl p-4 border border-[rgba(45,78,216,0.2)] mt-2">
                <div class="w-full h-12 flex items-end gap-1">
                  <div class="w-full bg-[var(--color-brand)]/40 h-[30%] rounded-t-sm"></div>
                  <div class="w-full bg-[var(--color-brand)]/60 h-[50%] rounded-t-sm"></div>
                  <div class="w-full bg-[var(--color-brand)]/80 h-[80%] rounded-t-sm"></div>
                  <div class="w-full bg-[var(--color-brand)] h-[100%] rounded-t-sm"></div>
                  <div class="w-full bg-[var(--color-brand)]/70 h-[60%] rounded-t-sm"></div>
                  <div class="w-full bg-[var(--color-brand)]/90 h-[90%] rounded-t-sm"></div>
                </div>
              </div>
            </div>
          </div>

          <!-- Card 1 (Front) - Code Editor -->
          <div class="hero-card-front">
            <div class="flex items-center gap-2 px-4 py-3 border-b border-white/10 bg-white/5">
              <div class="w-3 h-3 rounded-full bg-[#ff5f56]"></div>
              <div class="w-3 h-3 rounded-full bg-[#ffbd2e]"></div>
              <div class="w-3 h-3 rounded-full bg-[#27c93f]"></div>
              <span class="ml-2 text-xs font-mono text-[var(--color-ink-subtle)]">optimize_graph.ts</span>
            </div>
            <div class="p-5 font-mono text-[0.8rem] leading-relaxed text-[#c9d1d9] overflow-hidden">
              <pre><code><span class="text-[#ff7b72]">async function</span> <span class="text-[#d2a8ff]">resolveDependency</span>(
  <span class="text-[#79c0ff]">node</span>: ActionNode
): <span class="text-[#79c0ff]">Promise</span>&lt;Result&gt; {'{'}
  <span class="text-[#ff7b72]">const</span> ctx = <span class="text-[#ff7b72]">await</span> initContext();

  <span class="text-[#8b949e]">/* AI driven sub-routine */</span>
  <span class="text-[#ff7b72]">if</span> (node.<span class="text-[#79c0ff]">isDynamic</span>) {'{'}
    <span class="text-[#ff7b72]">return</span> <span class="text-[#ff7b72]">await</span> llm.predictPath(ctx);
  {'}'}

  <span class="text-[#ff7b72]">return</span> execute(node, ctx);
{'}'}</code></pre>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Proof Points + Capabilities -->
    <div class="hero-bottom reveal" data-reveal style="--delay:220ms;">
      <div class="hero-proof">
        {proofRows.map((item) => (
          <div>
            <div class="text-xs font-bold text-[var(--color-ink-subtle)] uppercase font-mono mb-1">{item.index}</div>
            <div class="font-bold text-[var(--color-ink)] text-lg">{item.label}</div>
            <div class="text-sm text-[var(--color-ink-muted)]">{item.text}</div>
          </div>
        ))}
      </div>

      <div class="hero-capabilities">
        {capabilityRows.map((item) => (
          <div class="hero-capability">
            <div class="icon-box">
              <Icon name={item.icon} size={16} class="text-[var(--color-ink)]" />
            </div>
            <div>
              <h2 class="hero-capability-label">{item.label}</h2>
              <p class="hero-capability-text">{item.text}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .hero-shell {
    position: relative;
    overflow: clip;
    min-height: calc(100svh - 4rem);
  }

  .hero-atmosphere {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .hero-grid {
    position: absolute;
    inset: 4% 0 0;
    background:
      linear-gradient(90deg, rgba(18, 20, 23, 0.04) 1px, transparent 1px),
      linear-gradient(rgba(18, 20, 23, 0.04) 1px, transparent 1px);
    background-size: 48px 48px;
    mask-image: radial-gradient(circle at 68% 28%, black 0, black 28%, transparent 70%);
    -webkit-mask-image: radial-gradient(circle at 68% 28%, black 0, black 28%, transparent 70%);
    opacity: 0.55;
  }

  .hero-orb {
    position: absolute;
    border-radius: 9999px;
    filter: blur(12px);
  }

  .hero-orb-a {
    top: -10%;
    right: -5%;
    width: clamp(14rem, 35vw, 35rem);
    height: clamp(14rem, 35vw, 35rem);
    background: radial-gradient(circle, rgba(45, 78, 216, 0.12) 0%, rgba(243, 238, 228, 0) 70%);
    animation: floatOrb 20s ease-in-out infinite alternate;
  }

  .hero-orb-b {
    top: -20%;
    left: -10%;
    width: clamp(12rem, 30vw, 30rem);
    height: clamp(12rem, 30vw, 30rem);
    background: radial-gradient(circle, rgba(255, 255, 255, 0.6) 0%, rgba(243, 238, 228, 0) 70%);
    animation: floatOrb 15s ease-in-out infinite alternate-reverse;
  }

  @keyframes floatOrb {
    0% { transform: translate(0, 0) scale(1); }
    100% { transform: translate(-30px, 50px) scale(1.05); }
  }

  .hero-layout {
    position: relative;
    display: grid;
    gap: 2.75rem;
    align-items: center;
  }

  .hero-site-title {
    font-size: clamp(3rem, 6vw, 5.5rem);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--color-ink);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-top: 2.5rem;
  }

  /* Stacked cards */
  .hero-cards-stack {
    position: relative;
    height: 500px;
  }

  .hero-card-back {
    position: absolute;
    top: 12px;
    right: 0;
    width: 420px;
    height: 320px;
    padding: 1.5rem;
    transform: rotate(-6deg) translateX(40px) translateY(-20px) scale(0.9);
    opacity: 0.4;
    z-index: 1;
    pointer-events: none;
  }

  .hero-card-back:hover {
    transform: rotate(-6deg) translateX(40px) translateY(-20px) scale(0.9);
  }

  .hero-card-mid {
    position: absolute;
    top: 16px;
    left: 48px;
    width: 380px;
    height: 360px;
    padding: 1.5rem;
    transform: rotate(3deg) translateX(-20px) translateY(20px) scale(0.95);
    opacity: 0.8;
    z-index: 2;
    display: flex;
    flex-direction: column;
  }

  .hero-card-mid:hover {
    transform: rotate(3deg) translateX(-20px) translateY(20px) scale(0.95);
  }

  .hero-card-front {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 400px;
    height: 280px;
    transform: translateX(-10%) translateY(10%);
    z-index: 3;
    overflow: hidden;
    border-radius: var(--radius-xl);
    box-shadow: 0 30px 80px -20px rgba(45, 78, 216, 0.15);
    display: flex;
    flex-direction: column;
    background: #121417;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  /* Bottom section */
  .hero-bottom {
    margin-top: 8rem;
    padding-top: 3rem;
    border-top: 1px solid rgba(18, 20, 23, 0.08);
    display: grid;
    gap: 3rem;
  }

  .hero-proof {
    display: flex;
    flex-wrap: wrap;
    gap: 3rem;
  }

  .hero-capabilities {
    display: grid;
    gap: 1rem;
  }

  .hero-capability {
    padding: 1.25rem;
    border: 1px solid rgba(18, 20, 23, 0.08);
    border-radius: var(--radius-lg);
    background: rgba(255, 255, 255, 0.3);
    backdrop-filter: blur(8px);
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 0.95rem;
    align-items: start;
  }

  .hero-capability-label {
    margin-bottom: 0.3rem;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-ink);
  }

  .hero-capability-text {
    font-size: 0.85rem;
    line-height: 1.65;
    color: var(--color-ink-muted);
  }

  @media (min-width: 960px) {
    .hero-layout {
      grid-template-columns: minmax(0, 1fr) minmax(22rem, 1fr);
      gap: 4rem;
    }

    .hero-bottom {
      grid-template-columns: auto 1fr;
      gap: 4rem;
    }

    .hero-capabilities {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 959px) {
    .hero-shell {
      min-height: auto;
    }

    .hero-cards-stack {
      display: none;
    }
  }

  @media (max-width: 767px) {
    .hero-grid {
      mask-image: radial-gradient(circle at 50% 25%, black 0, black 20%, transparent 68%);
      -webkit-mask-image: radial-gradient(circle at 50% 25%, black 0, black 20%, transparent 68%);
      opacity: 0.4;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-orb-a,
    .hero-orb-b {
      animation: none;
    }
  }
</style>
