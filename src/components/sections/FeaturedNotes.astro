---
import Icon from '@/components/icons/Icons.astro'
import type { Note } from '@/types'

interface Props {
  notes: Note[]
}

const { notes } = Astro.props

const kindConfig: Record<string, { label: string; css: string }> = {
  log: { label: 'Log', css: 'badge-planning' },
  howto: { label: 'How-to', css: 'badge-building' },
  'case-study': { label: 'Case Study', css: 'badge-live' },
  thinking: { label: 'Thinking', css: 'badge-archived' },
}
---

{notes.length > 0 && (
  <section class="py-[var(--space-section-sm)] md:py-[var(--space-section)]">
    <div class="max-w-[1280px] mx-auto px-6 md:px-12">
      <div class="mb-10 reveal" data-reveal>
        <p class="section-label text-[var(--color-ink-muted)] mb-3">Notes</p>
        <h2 class="page-title">設計判断を、短く残す。</h2>
      </div>

      <div class="w-full max-w-[900px] border-t border-[var(--color-border)]">
        {notes.map((note, index) => {
          const publishedDate = note.publishedAt
            ? new Date(note.publishedAt).toLocaleDateString('ja-JP', { year: 'numeric', month: '2-digit', day: '2-digit' })
            : ''
          const kind = note.kind?.[0]
          const config = kind ? kindConfig[kind] : null

          return (
            <a
              href={`/notes/${note.slug}`}
              class="note-row reveal"
              data-reveal
              style={`--delay:${index * 90}ms;`}
            >
              <div class="flex flex-col gap-4 md:flex-row md:items-center md:gap-8">
                <div class="flex items-center gap-4 md:w-1/4 shrink-0">
                  <span class="text-sm font-mono text-[var(--color-ink-subtle)] w-20">{publishedDate || 'Draft'}</span>
                  {config && <span class:list={['badge', config.css]}>{config.label}</span>}
                </div>
                <div class="flex-grow">
                  <h3 class="text-lg font-bold text-[var(--color-ink)] mb-1 transition-colors group-hover:text-[var(--color-brand)]">
                    {note.title}
                  </h3>
                  <p class="text-[0.85rem] text-[var(--color-ink-muted)] truncate max-w-lg">{note.excerpt}</p>
                </div>
                <div class="hidden md:flex justify-end text-[var(--color-ink-subtle)] note-row-arrow">
                  <Icon name="arrow-right" size={16} />
                </div>
              </div>
            </a>
          )
        })}
      </div>

      <div class="mt-8 reveal" data-reveal>
        <a href="/notes" class="group hairline-link text-[var(--color-brand)] hover:text-[var(--color-ink)]">
          View all notes
          <Icon name="arrow-right" size={14} class="hover-arrow" />
        </a>
      </div>
    </div>
  </section>
)}
