---
import BuildCard from '@/components/cards/BuildCard.astro'
import Icon from '@/components/icons/Icons.astro'
import type { Build } from '@/types'

interface Props {
  builds: Build[]
}

const { builds } = Astro.props
---

{builds.length > 0 && (
  <section class="py-[var(--space-section-sm)] md:py-[var(--space-section)]">
    <div class="max-w-[1280px] mx-auto px-6 md:px-12">
      <div class="mb-12 reveal" data-reveal>
        <p class="section-label text-[var(--color-brand)] mb-3">Selected Builds</p>
        <h2 class="page-title">実装を、輪郭ごと見せる。</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {builds.map((build, index) => (
          <div class="reveal" data-reveal style={`--delay:${index * 90}ms;`}>
            <BuildCard build={build} />
          </div>
        ))}
      </div>

      <div class="mt-10 reveal" data-reveal>
        <a href="/builds" class="group hairline-link">
          View all builds
          <Icon name="arrow-right" size={14} class="hover-arrow" />
        </a>
      </div>
    </div>
  </section>
)}
