---
interface Props {
  xUrl?: string
  githubUrl?: string
}

const { xUrl, githubUrl } = Astro.props
const year = new Date().getFullYear()
---

<footer class="border-t border-[rgba(18,20,23,0.06)] mt-10 bg-[var(--color-paper)] relative z-10">
  <div class="max-w-[1280px] mx-auto px-6 md:px-12 pt-16 pb-8">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-8 mb-12">
      <div>
        <a href="/" class="flex items-center gap-2 mb-2">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" class="text-[var(--color-brand)]">
            <path d="M7 8l5-5 5 5M7 16l5 5 5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span class="text-xl font-bold tracking-tight text-[var(--color-ink)]">bykamo.dev</span>
        </a>
        <p class="text-sm text-[var(--color-ink-muted)]">AIとコードで、情報・運用・体験を組み直す。</p>
      </div>

      <div class="flex flex-col gap-5 md:items-end">
        <nav class="flex flex-wrap items-center gap-x-6 gap-y-2 text-sm font-medium text-[var(--color-ink-muted)]">
          <a href="/builds" class="hover:text-[var(--color-ink)] transition-colors">Builds</a>
          <a href="/notes" class="hover:text-[var(--color-ink)] transition-colors">Notes</a>
          <a href="/about" class="hover:text-[var(--color-ink)] transition-colors">About</a>
          <a href="/contact" class="hover:text-[var(--color-ink)] transition-colors">Contact</a>
        </nav>

        {(xUrl || githubUrl) && (
          <div class="flex items-center gap-3">
            {xUrl && (
              <a href={xUrl} target="_blank" rel="noopener noreferrer" aria-label="X" class="flex items-center gap-2 text-sm text-[var(--color-ink-muted)] hover:text-[var(--color-ink)] transition-colors">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
                </svg>
                X
              </a>
            )}
            {githubUrl && (
              <a href={githubUrl} target="_blank" rel="noopener noreferrer" aria-label="GitHub" class="flex items-center gap-2 text-sm text-[var(--color-ink-muted)] hover:text-[var(--color-ink)] transition-colors">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
                </svg>
                GitHub
              </a>
            )}
          </div>
        )}
      </div>
    </div>

    <div class="flex flex-col md:flex-row justify-between items-center pt-8 border-t border-[rgba(18,20,23,0.04)] text-[0.75rem] font-mono text-[var(--color-ink-subtle)]">
      <p>&copy; {year} KAMO</p>
      <div class="flex items-center gap-2 mt-4 md:mt-0">
        <span class="w-2 h-2 rounded-full bg-[var(--color-live)] animate-pulse"></span>
        System Operational
      </div>
    </div>
  </div>
</footer>
