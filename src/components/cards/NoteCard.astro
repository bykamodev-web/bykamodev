---
import type { Note } from '@/types'
import Icon from '@/components/icons/Icons.astro'

interface Props {
  note: Note
}

const { note } = Astro.props

const publishedDate = note.publishedAt
  ? new Date(note.publishedAt).toLocaleDateString('ja-JP', { year: 'numeric', month: 'short', day: 'numeric' })
  : ''

const kindConfig: Record<string, { label: string; css: string }> = {
  log: { label: 'Log', css: 'badge-planning' },
  howto: { label: 'How-to', css: 'badge-building' },
  'case-study': { label: 'Case Study', css: 'badge-live' },
  thinking: { label: 'Thinking', css: 'badge-archived' },
}

const kind = note.kind?.[0]
const config = kind ? kindConfig[kind] : null
---

<a href={`/notes/${note.slug}`} class="group block h-full">
  <article class="note-tile h-full">
    <div class="note-meta">
      {config && (
        <span class:list={['badge', config.css]}>{config.label}</span>
      )}
      {note.topics?.slice(0, 2).map((topic) => (
        <span class="caption">{topic.title}</span>
      ))}
    </div>

    <div class="flex items-start justify-between gap-4">
      <h3 class="note-title">{note.title}</h3>
      <Icon name="arrow-right" size={16} class="hover-arrow mt-1 text-[var(--color-ink-subtle)]" />
    </div>

    <p class="note-excerpt">{note.excerpt}</p>

    {publishedDate && (
      <div class="note-date">
        <Icon name="calendar" size={12} class="text-[var(--color-ink-subtle)]" />
        <time class="caption" datetime={note.publishedAt}>
          {publishedDate}
        </time>
      </div>
    )}
  </article>
</a>

<style>
  .note-tile {
    display: flex;
    flex-direction: column;
    padding-top: 1rem;
    border-top: 1px solid rgba(18, 20, 23, 0.1);
  }

  .note-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    align-items: center;
    margin-bottom: 1rem;
  }

  .note-title {
    font-size: 1.02rem;
    font-weight: 700;
    line-height: 1.34;
    letter-spacing: -0.03em;
    color: var(--color-ink);
    transition: color 180ms ease;
  }

  .note-excerpt {
    margin-top: 0.9rem;
    font-size: 0.93rem;
    line-height: 1.72;
    color: var(--color-ink-muted);
  }

  .note-date {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    margin-top: auto;
    padding-top: 1rem;
  }

  .group:hover .note-title {
    color: var(--color-brand);
  }

  @media (prefers-reduced-motion: reduce) {
    .note-title {
      transition: none;
    }
  }
</style>
